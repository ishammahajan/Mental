# Gemini API Key (Google AI Studio — free tier)
GEMINI_API_KEY=
API_KEY=

# HuggingFace Token — OPTIONAL (free at huggingface.co/settings/tokens)
# Increases rate limits for the mental health specialist sentiment model
# Model used: j-hartmann/emotion-english-distilroberta-base (free, no token needed for basic use)
VITE_HF_TOKEN=

# Backend server env vars (used by server/index.js)
HF_TOKEN=
RESEND_API_KEY=
EMAIL_FROM=Maker Lab <no-reply@tasks-no-reply.isham.in>

# Frontend email endpoint config

# Optional fallback: custom backend route URL
VITE_EMAIL_API_URL=https://emailserver2.netlify.app/api/email/send`
